# =====================================================
# QRCerts - Variables de entorno
# Copiar a .env (NO commitear) y completar con valores reales
# =====================================================

# Password de SA para SQL Server (minimo 8 chars, mayuscula, numero, simbolo)
SQL_SA_PASSWORD=CambiarPorPasswordFuerte!

# Clave JWT - debe ser larga y random (>= 32 chars)
JWT_KEY=cambiar-por-secret-largo-y-random-min-32-chars

# URL base del QR (apunta al dominio publico de la instancia)
QR_BASE_URL=https://TU-DOMINIO/app/#/validar?data=

# Puerto host donde se expone la app (host:80 -> contenedor)
APP_PORT=8088
